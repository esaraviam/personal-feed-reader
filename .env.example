# Copy to .env.local for local dev, or set in your hosting provider for production.

# Your deployed Cloudflare Worker URL (no trailing slash)
# Leave blank to skip the worker and use public proxies only.
VITE_PROXY_URL=https://daily-brief-proxy.millamanque.workers.dev

# Optional: AUTH_KEY you set via `wrangler secret put AUTH_KEY`
# Only needed if you secured the worker with a key.
VITE_PROXY_KEY=
